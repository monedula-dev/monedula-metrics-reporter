            "lastNotNull",
            "max"
          ]
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Produce Request Total Time (p50 / p95 / p99)",
      "description": "Quantile breakdown for the Produce path.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kafka_network_requestmetrics_totaltimems{kafka_cluster_id=~\"$cluster_id\", kafka_node_id=~\"$node_id\", request=\"Produce\", quantile=\"0.5\"}",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
