        },
        {
          "expr": "kafka_network_requestmetrics_totaltimems{kafka_cluster_id=~\"$cluster_id\", kafka_node_id=~\"$node_id\", request=\"Produce\", quantile=\"0.99\"}",
          "legendFormat": "p99",
