      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kafka_network_requestmetrics_totaltimems{kafka_cluster_id=~\"$cluster_id\", kafka_node_id=~\"$node_id\", quantile=\"0.99\"}",
          "legendFormat": "{{request}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
